      "group": "challenge_core",
      "chance": 100,
      "sticky_turns": 0,
      "cooldown_turns": 0,
      "order": 0,
      "priority": 0,
      "insertion_position": "before_char_defs",
      "injection_depth": 0,
      "injection_order": 20,
      "injection_role": "system",
      "prompt_layer": "stable",
      "recursive_enabled": false,
      "prevent_further_recursion": false,
      "enabled": true,
      "case_sensitive": false,
      "whole_word": false,
      "comment": "挑战模式基础世界观。"
    },
    {
