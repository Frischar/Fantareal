    {
      "id": "wb_xuqi_v2_corridor_core",
      "title": "绝望回廊核心设定 v2",
      "trigger": "常驻,绝望回廊,绪亓,挑战模式,深层档案",
      "secondary_trigger": "",
      "entry_type": "constant",
      "group_operator": "and",
      "match_mode": "includes",
      "secondary_mode": "includes",
