      "group_operator": "and",
      "match_mode": "includes",
      "secondary_mode": "includes",
      "content": "【系统规则】希望影响绪亓是否愿意继续；信任影响她是否主动交出线索；稳定度影响叙事连贯；认知清晰度影响她识别真假记忆；回声侵蚀影响门后声音的干扰；门压影响是否能接近最终门。温柔、耐心、复述线索会提升希望/信任/稳定；逼问、否定、急于开门会提升绝望/回声/门压。",
      "group": "challenge_core",
      "chance": 100,
      "sticky_turns": 0,
      "cooldown_turns": 0,
      "order": 1,
      "priority": 1,
      "insertion_position": "before_char_defs",
